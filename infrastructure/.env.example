# Quantis Infrastructure Environment Variables
# Copy to .env and fill in real values - DO NOT commit .env to version control

# Database
DB_ROOT_PASSWORD=change_me_root_password_min_16_chars
DB_PASSWORD=change_me_app_password_min_16_chars
DB_USER=appuser
DB_NAME=quantisdb

# API
API_SECRET=change_me_api_secret_min_32_chars

# Redis
REDIS_PASSWORD=change_me_redis_password

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password

# Application
LOG_LEVEL=info
