# Quantis Infrastructure Configuration Example
# Copy to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars with real secrets to version control

aws_region  = "us-west-2"
environment = "dev"
app_name    = "quantis"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-west-2a", "us-west-2b", "us-west-2c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]

instance_type = "t3.micro"
key_name      = null  # Set to your EC2 key pair name if SSH access needed

db_instance_class = "db.t3.micro"
db_name           = "quantisdb"
db_username       = "quantis_admin"
# IMPORTANT: Never set db_password here. Use environment variable instead:
# export TF_VAR_db_password="your-minimum-16-char-password"

default_tags = {
  Terraform   = "true"
  Environment = "dev"
  Project     = "quantis"
  ManagedBy   = "terraform"
}
