{
  "dashboard": {
    "id": null,
    "uid": "quantis-model-perf",
    "title": "Model Performance",
    "tags": ["quantis", "ml", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Data Drift (KL Divergence)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [{ "expr": "data_drift", "legendFormat": "KL Divergence" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.5 },
                { "color": "red", "value": 1.0 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "GPU Utilization",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "nvidia_gpu_duty_cycle", "legendFormat": "GPU %" }
        ],
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 3,
        "title": "Concept Drift",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "concept_drift", "legendFormat": "Performance Degradation" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 4,
        "title": "Prediction Latency (P95)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
            "legendFormat": "P95 Latency"
          },
          {
            "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
            "legendFormat": "P50 Latency"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 5,
        "title": "Predictions per Second",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "rate(predictions_total[1m])", "legendFormat": "RPS" }
        ],
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 }
      }
    ]
  },
  "overwrite": true
}
